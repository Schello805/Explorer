ADMIN_EMAIL=admin@schellenberger.biz
ADMIN_PASSWORD_HASH=
AUTH_SECRET=replace-with-at-least-32-random-characters
NEXT_PUBLIC_APP_REVISION=dev
NEXT_PUBLIC_GITHUB_URL=https://github.com/Schello805/Explorer
# Optional. Leer lassen für lokale Demo-Daten ohne PostgreSQL.
DATABASE_URL=
ALLOW_PUBLIC_SIGNUP=false
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Optional: HTTP-Webhook für transaktionale E-Mails. Ohne Webhook landen Mails lokal in .data/mail-outbox.json.
MAIL_PROVIDER=outbox
MAIL_FROM=noreply@example.org
MAIL_FROM_NAME=Platzguide
MAIL_WEBHOOK_URL=
RESEND_API_KEY=
BREVO_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
CAPTCHA_PROVIDER=disabled
NEXT_PUBLIC_CAPTCHA_SITE_KEY=
TURNSTILE_SECRET_KEY=
HCAPTCHA_SECRET_KEY=
UPLOAD_MAX_MB=10
